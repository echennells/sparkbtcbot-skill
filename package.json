{
  "name": "sparkbtcbot-skill",
  "version": "0.1.0",
  "type": "module",
  "description": "Claude Code skill for setting up Spark Bitcoin L2 wallet capabilities for AI agents",
  "dependencies": {
    "@buildonspark/issuer-sdk": "^0.1.35",
    "@buildonspark/spark-sdk": "^0.7.17",
    "dotenv": "^16.4.7",
    "light-bolt11-decoder": "^3.2.0"
  },
  "scripts": {
    "example:setup": "node skills/sparkbtcbot/scripts/wallet-setup.js",
    "example:balance": "node skills/sparkbtcbot/scripts/balance-and-deposits.js",
    "example:payments": "node skills/sparkbtcbot/scripts/payment-flow.js",
    "example:tokens": "node skills/sparkbtcbot/scripts/token-operations.js",
    "example:agent": "node skills/sparkbtcbot/scripts/spark-agent.js",
    "example:l402": "node skills/sparkbtcbot/scripts/l402-paywalls.js",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --exclude tests/integration/funded",
    "test:funded": "vitest run tests/integration/funded",
    "test:all": "vitest run"
  },
  "devDependencies": {
    "vitest": "4.1.5"
  }
}
